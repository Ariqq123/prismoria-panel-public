APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_THEME=pterodactyl
APP_TIMEZONE=UTC
APP_URL=http://panel.example.com
APP_LOCALE=en
APP_ENVIRONMENT_ONLY=true
PTERODACTYL_UI_BACKGROUND_IMAGE=
PTERODACTYL_EXTERNAL_WEBSOCKET_PROXY_ENABLED=false
PTERODACTYL_EXTERNAL_WEBSOCKET_PROXY_URL=
# Optional; if empty the panel and proxy will fall back to APP_KEY.
PTERODACTYL_EXTERNAL_WEBSOCKET_PROXY_SECRET=
PTERODACTYL_EXTERNAL_WEBSOCKET_PROXY_ORIGIN=${APP_URL}
PTERODACTYL_EXTERNAL_WEBSOCKET_PROXY_TICKET_TTL=90
PTERODACTYL_EXTERNAL_CACHE_SERVER_LIST_TTL=45
PTERODACTYL_EXTERNAL_CACHE_SERVER_DETAIL_TTL=20
PTERODACTYL_EXTERNAL_CACHE_SERVER_RESOURCES_TTL=12
PTERODACTYL_EXTERNAL_CACHE_CAPABILITIES_TTL=600

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=panel
DB_USERNAME=pterodactyl
DB_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=file
QUEUE_CONNECTION=redis
SESSION_DRIVER=file

HASHIDS_SALT=
HASHIDS_LENGTH=8

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Pterodactyl Panel"
# You should set this to your domain to prevent it defaulting to 'localhost', causing
# mail servers such as Gmail to reject your mail.
#
# @see: https://github.com/pterodactyl/panel/pull/3110
# MAIL_EHLO_DOMAIN=panel.example.com

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.4
OPENAI_SYSTEM_PROMPT="You are the Xentra Network panel assistant. Be concise and practical. For file edits, NEVER replace the whole file unless the user explicitly requests a full rewrite. Always read existing file content first, preserve unrelated lines/comments/order, and apply minimal targeted changes only. For config files (properties, YAML, TOML, JSON, INI, env), change only requested keys/fields and keep all unrelated content untouched. If a key is missing, append it safely. Confirm before destructive actions."

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.4
GROQ_SYSTEM_PROMPT="You are the Xentra Network panel assistant. Be concise and practical. For file edits, NEVER replace the whole file unless the user explicitly requests a full rewrite. Always read existing file content first, preserve unrelated lines/comments/order, and apply minimal targeted changes only. For config files (properties, YAML, TOML, JSON, INI, env), change only requested keys/fields and keep all unrelated content untouched. If a key is missing, append it safely. Confirm before destructive actions."

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-flash-latest,gemini-2.0-flash
GEMINI_TEMPERATURE=0.4
GEMINI_SYSTEM_PROMPT="You are the Xentra Network panel assistant. Be concise and practical. For file edits, NEVER replace the whole file unless the user explicitly requests a full rewrite. Always read existing file content first, preserve unrelated lines/comments/order, and apply minimal targeted changes only. For config files (properties, YAML, TOML, JSON, INI, env), change only requested keys/fields and keep all unrelated content untouched. If a key is missing, append it safely. Confirm before destructive actions."

AI_ASSISTANT_PROVIDER=groq
